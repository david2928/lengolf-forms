# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Word temp/lock files
~$*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
test-results/
playwright-report/
.nyc_output/
junit.xml
test-report.html

# playwright specific
playwright/.cache/
playwright/screenshots/
playwright/videos/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code configuration (ignore only personal settings, keep project configs)
.claude/settings*.json
.claude/launch.json
.claude/skills/
.claude/worktrees/

# superpowers (local tooling config and plans)
.superpowers/
docs/superpowers/

# misc files in project root (images, PDFs, CSVs)
*.jpg
*.png
*.pdf
*.csv
!src/**
!public/**
!app/**

# e2e sample data and eval results (generated locally)
scripts/e2e-samples/*.json
scripts/eval-e2e-results.json
scripts/test-intent-classifier.ts

# audit files (sensitive financial/tax documents)
/audit/
.mcp.json
